# Jinni AI Backend Configuration
# 复制此文件为 .env 并填入真实配置

# ============================================================
# Server Configuration
# ============================================================
PORT=8000
HOST=0.0.0.0

# ============================================================
# AI Service Providers
# ============================================================

# Transcription Provider (fallback, whisper, faster-whisper, openai)
AI_TRANSCRIPTION_PROVIDER=fallback

# Summary Provider (fallback, openai, anthropic, ollama, deepseek)
AI_SUMMARY_PROVIDER=fallback

# ============================================================
# Transcription Configuration (真实转录 provider)
# ============================================================

# Whisper ASR 配置（本地模型，无需 API Key）
WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=zh
WHISPER_DEVICE=auto  # auto, cpu, cuda

# OpenAI Whisper API 配置（如果使用 OpenAI Whisper）
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TRANSCRIPTION_TIMEOUT_SECONDS=300

# ============================================================
# Summary Configuration (本阶段不启用，保持 fallback)
# ============================================================

# LLM Provider (ollama, openai, anthropic, deepseek)
LLM_PROVIDER=ollama

# OpenAI Configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# DeepSeek Configuration
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

# ============================================================
# Service Configuration
# ============================================================

# Processing timeouts (seconds)
TRANSCRIPTION_TIMEOUT=300
SUMMARY_TIMEOUT=120

# ============================================================
# Upload Configuration
# ============================================================
MAX_FILE_SIZE_MB=500
UPLOAD_DIR=./uploads

# ============================================================
# CORS Configuration
# ============================================================
# Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8501,http://127.0.0.1:8501

# ============================================================
# Development Options
# ============================================================
# Debug mode (prints detailed logs)
DEBUG=true

# Mock mode (use mock responses even if real services are available)
# Set to 'true' for testing without real AI services
USE_MOCK_SERVICES=false
