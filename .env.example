# AI Meeting Assistant - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# LLM Provider API Keys (至少配置一个)
# ============================================

# OpenAI API Key (for GPT models)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-key-here>

# Anthropic API Key (for Claude models)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=<your-anthropic-key-here>

# Zhipu AI API Key (for GLM models)
# Get from: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=<your-zhipu-key-here>

# DeepSeek API Key (for DeepSeek models)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=<your-deepseek-key-here>

# ============================================
# Default LLM Settings
# ============================================

# Default LLM provider: openai, anthropic, glm, or deepseek
DEFAULT_LLM_PROVIDER=deepseek

# Default model for the provider
# OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
# GLM: glm-4-flash, glm-4-plus, glm-4
DEFAULT_LLM_MODEL=glm-4-flash

# ============================================
# ASR Settings (Optional)
# ============================================

# Whisper model size: tiny, base, small, medium, large
# Smaller = faster, larger = more accurate
WHISPER_MODEL_SIZE=base

# ============================================
# Summary Provider Configuration
# ============================================

# Summary provider: fallback, backend, openai, anthropic, ollama, deepseek
AI_SUMMARY_PROVIDER=backend

# LLM provider for summary generation: openai, ollama
LLM_PROVIDER=openai

# OpenAI-compatible API configuration (for DeepSeek)
OPENAI_API_KEY=<your-deepseek-key-here>
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ============================================
# Transcription Provider Configuration (阶段 10B)
# ============================================

# Transcription provider: fallback, whisper, whisperx
TRANSCRIPTION_PROVIDER=whisperx

# WhisperX configuration
WHISPERX_MODEL=large-v3-turbo
WHISPERX_LANGUAGE=zh
WHISPERX_DEVICE=auto  # auto, cuda, cpu
WHISPERX_COMPUTE_TYPE=  # auto, int8, float16, float32
WHISPERX_BATCH_SIZE=16
WHISPERX_SKIP_ALIGN=false

# ============================================
# Speaker Diarization Configuration (阶段 10B)
# ============================================

# Enable speaker diarization (说话人分离)
DIARIZATION_ENABLED=true

# Pyannote diarization model
PYANNOTE_DIARIZE_MODEL=pyannote/speaker-diarization-community-1

# Hugging Face token (required for pyannote models)
# Get from: https://huggingface.co/settings/tokens
# You must accept the model license at: https://huggingface.co/pyannote/speaker-diarization-community-1
HF_TOKEN=
HUGGINGFACE_TOKEN=

# Diarization parameters
DIARIZATION_MIN_SPEAKERS=
DIARIZATION_MAX_SPEAKERS=
DIARIZATION_MERGE_GAP=1.0  # seconds

# ============================================
# Advanced Settings (Optional)
# ============================================

# Custom config file path (overrides default config.yaml)
# MEETING_ASSISTANT_CONFIG=/path/to/custom/config.yaml
