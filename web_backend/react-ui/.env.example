# Vite React Frontend Configuration
# 复制此文件为 .env 并根据需要修改

# ============================================================
# API Configuration
# ============================================================

# Backend API Base URL
# 开发环境使用代理（/api），生产环境需要设置完整URL
VITE_API_BASE_URL=/api

# 生产环境示例：
# VITE_API_BASE_URL=https://api.jinni.ai

# ============================================================
# Feature Flags
# ============================================================

# 启用/禁用特定功能
VITE_ENABLE_TEMPLATES=true
VITE_ENABLE_EXPORT=true
VITE_ENABLE_SETTINGS=true

# ============================================================
# UI Configuration
# ============================================================

# 默认每页显示的项目数
VITE_ITEMS_PER_PAGE=20

# 文件上传大小限制（MB）
VITE_MAX_UPLOAD_SIZE_MB=500

# ============================================================
# Development Options
# ============================================================

# 显示调试信息
VITE_DEBUG=true

# 模拟模式（使用模拟数据）
VITE_USE_MOCK_DATA=false
